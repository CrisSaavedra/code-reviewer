    "outDir": "dist",
    "rootDir": "src",
    "allowImportingTsExtensions": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "src/__tests__"]
}
