{
  "name": "code-reviewer-cli",
  "version": "0.1.0",
  "description": "A keyboard-driven terminal tool for reviewing local git diff changes",
  "type": "module",
  "bin": {
    "cr": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "packageManager": "bun@1.3.11",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "dev": "bun --watch src/cli.ts",
    "build": "bun run clean && bunx tsc -p tsconfig.build.json",
    "test": "bunx vitest",
    "test:run": "bunx vitest run",
    "lint": "bunx eslint src/**",
    "format": "bunx prettier . --write"
  },
  "keywords": [
    "cli",
    "git",
    "code-review",
    "terminal"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "chalk": "^5.3.0",
    "clipboardy": "^4.0.0",
    "commander": "^12.0.0",
    "execa": "^9.0.0",
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "react": "^18.2.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsconfig/node-lts": "^20.1.3",
    "@types/bun": "^1.3.11",
    "@types/react": "^18.2.0",
    "eslint": "^10.2.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "3.8.1",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.3"
  }
}
